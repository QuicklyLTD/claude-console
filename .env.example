# Claude Console — environment

# HTTP + WS port for the backend
PORT=5180

# Bind host (use 127.0.0.1 for local-only; 0.0.0.0 for LAN access)
HOST=127.0.0.1

# Default working directory for new sessions (omit → server cwd)
CLAUDE_CWD=

# Default model for new sessions (sonnet | opus | haiku | claude-sonnet-4-6 …)
CLAUDE_MODEL=

# Default permission mode (default | acceptEdits | plan | bypassPermissions)
CLAUDE_PERMISSION_MODE=default

# Additional dirs (`;` separated) appended to every session
CLAUDE_ADD_DIRS=

# Optional cap on agentic turns per request
CLAUDE_MAX_TURNS=

# Shared token required on the WS query-string (?token=...). Empty = open.
BRIDGE_TOKEN=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# If ANTHROPIC_API_KEY is set, the SDK uses it; otherwise falls back to
# the OAuth creds from `claude login` (subscription billing).
ANTHROPIC_API_KEY=
